+    // Faster chunk serialization
+    private static Optional<LongStream> asOptional(final long[] values) {
+        return Optional.of(Arrays.stream(values));
+    }
+
+    private static short[] getOrCreateShortArray(final int size) {
+        return switch (size) {
+            case 64 -> CACHED_SHORT_ARRAY_64.get();
+            case 4096 -> CACHED_SHORT_ARRAY_4096.get();
+            default -> new short[size];
+        };
+    }
+
+    @Override
+    public synchronized PalettedContainerRO.PackedData<T> pack(final Strategy<T> strategy) { // Paper - synchronize
+        this.acquire();
+
+        try {
+            final BitStorage currentStorage = this.data.storage;
+            final Palette<T> currentPalette = this.data.palette;
+            if (currentStorage instanceof ZeroBitStorage || currentPalette.getSize() == 1) {
+                return new PalettedContainerRO.PackedData<>(List.of(currentPalette.valueFor(0)), Optional.empty(), 0);
+            }
+
+            final int entryCount = strategy.entryCount();
+            final org.galemc.gale.util.collection.palette.SerializationPalette<T> compactedPalette = new org.galemc.gale.util.collection.palette.SerializationPalette<>(currentStorage.getBits());
+            final short[] remappedContents = getOrCreateShortArray(entryCount);
+            currentStorage.compact(currentPalette, compactedPalette, PaletteResize.noResizeExpected(), remappedContents);
+
+            final int bitsOnDisc = strategy.getConfigurationForPaletteSize(compactedPalette.getSize()).bitsInStorage();
+            Optional<LongStream> values = Optional.empty();
+            if (bitsOnDisc != 0) {
+                final SimpleBitStorage storage = new SimpleBitStorage(bitsOnDisc, entryCount, remappedContents);
+                values = asOptional(storage.getRaw());
+            }
+
+            return new PalettedContainerRO.PackedData<>(compactedPalette.getEntries(), values, bitsOnDisc);
+        } finally {
+            this.release();
+        }
+    }
+
     @Override
     public int getSerializedSize() {
         return this.data.getSerializedSize(this.strategy.globalMap());
@@ -426,10 +445,22 @@ public class PalettedContainer<T> implements PaletteResize<T>, PalettedContainer
     public void count(final PalettedContainer.CountConsumer<T> output) {
         if (this.data.palette.getSize() == 1) {
             output.accept(this.data.palette.valueFor(0), this.data.storage.getSize());
-        } else {
+        } else if (this.data.palette.getSize() > 4096) {
             Int2IntOpenHashMap counts = new Int2IntOpenHashMap();
             this.data.storage.getAll(state -> counts.addTo(state, 1));
             counts.int2IntEntrySet().forEach(entry -> output.accept(this.data.palette.valueFor(entry.getIntKey()), entry.getIntValue()));
+        } else {
+            final int paletteSize = this.data.palette.getSize();
+            final short[] counts = getOrCreateShortArray(paletteSize);
+            Arrays.fill(counts, 0, paletteSize, (short)0);
+            this.data.storage.getAll(state -> counts[state]++);
+
+            for (int paletteIndex = 0; paletteIndex < paletteSize; ++paletteIndex) {
+                final int count = counts[paletteIndex];
+                if (count != 0) {
+                    output.accept(this.data.palette.valueFor(paletteIndex), count);
+                }
+            }
         }
     }
 
