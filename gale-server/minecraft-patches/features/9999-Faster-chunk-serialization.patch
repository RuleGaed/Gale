 net/minecraft/util/SimpleBitStorage.java     | 64 ++++++++++++++
 net/minecraft/util/ZeroBitStorage.java       |  4 +
 .../world/level/chunk/PalettedContainer.java | 84 +++++++++++++------
 4 files changed, 127 insertions(+), 27 deletions(-)

